<meta name="theme-color" content="#d63384">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>

<header class="topbar">

<button class="menu-btn" onclick="openMenu()">
☰
</button>

<div class="logo">
<img src="img/NEXA.png" alt="NEXA Logo">
<h2>NEXA Community</h2>
</div>

<div class="top-icons">
<a href="notifications.html"><i class="fas fa-bell"></i></a>
<a href="profile.html"><i class="fas fa-user-circle"></i></a>
</div>

</header>

<div id="sideMenu" class="side-menu">

<button class="close-btn" onclick="closeMenu()">✖</button>

<a href="index.html">🏠 Home</a>
<a href="community.html">👥 Community</a>
<a href="chat.html">💬 Chats</a>
