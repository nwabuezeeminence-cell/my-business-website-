<a href="settings.html">⚙ Settings</a>
<a href="admin.html">🛠 Admin</a>

</div>

<main class="community-page">

<div class="create-post">

<h3>Create Post</h3>

<textarea
id="postInput"
placeholder="What's on your mind?">
</textarea>

<input
type="file"
id="postImage"
accept="image/*">

<button onclick="createPost()">
Post
</button>

</div>

<div id="feed">

<div class="post">

<div class="post-header">

<img
src="img/default-user.png"
class="avatar">

<div>

<h4>NEXA Digital Services</h4>

<small>Just now</small>

</div>

</div>

<p>
🎉 Welcome to the NEXA Community.
Share ideas, ask questions, and connect with everyone.
</p>

<div class="post-actions">

<button>👍 Like</button>

<button>💬 Comment</button>

<button>📤 Share</button>

</div>

</div>

</div>

</main>

